# CI build-root image for rosa-regional-platform-api PR checks.
# Used by ci-operator via build_root.project_image.dockerfile_path.

FROM registry.ci.openshift.org/openshift/release:rhel-9-release-golang-1.25-openshift-4.22

ARG GOLANGCI_LINT_VERSION=v2.1.6

# golangci-lint (pinned version, checksum-verified by install script)
RUN curl -sSfL "https://raw.githubusercontent.com/golangci/golangci-lint/${GOLANGCI_LINT_VERSION}/install.sh" \
    | sh -s -- -b /usr/local/bin "${GOLANGCI_LINT_VERSION}" && \
    golangci-lint --version

# Pre-create cache directories writable by any UID (OpenShift runs as random UID)
RUN mkdir -p /tmp/.golangci-lint-cache /tmp/.gocache && \
    chmod -R 777 /tmp/.golangci-lint-cache /tmp/.gocache

ENV GOLANGCI_LINT_CACHE=/tmp/.golangci-lint-cache
ENV GOCACHE=/tmp/.gocache
